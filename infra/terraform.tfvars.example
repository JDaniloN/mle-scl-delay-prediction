# Template: copy to terraform.tfvars and fill in (terraform.tfvars is often gitignored in public repos).
# project_id = "your-gcp-project"
# region     = "us-central1"
# app_name   = "mlops-challenge-api"
#
# First apply assumes an image already pushed to AR (docker push beforehand):
# image = "us-central1-docker.pkg.dev/your-gcp-project/mlops-challenge-api-repo/delay-api:1"

project_id = "YOUR_GCP_PROJECT_ID"
region     = "us-central1"
app_name   = "mlops-challenge-api"

# PROJECT and TAG after the first push (must match repository_id = "${app_name}-repo")
image = "us-central1-docker.pkg.dev/YOUR_GCP_PROJECT_ID/mlops-challenge-api-repo/delay-api:1"

# Optional: bump to 1 during challenge review to avoid cold start in Locust
# min_instances = 1

# Default true = request-based. For always-allocated CPU: cpu_request_based = false
# cpu_request_based = true
