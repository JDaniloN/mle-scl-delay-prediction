# Copia a terraform.tfvars y rellena (terraform.tfvars suele ignorarse en git en repos públicos).
# project_id = "tu-proyecto-gcp"
# region     = "us-central1"
# app_name   = "mlops-challenge-api"
#
# Debes hacer docker push ANTES del primer apply con una imagen que exista en AR:
# image = "us-central1-docker.pkg.dev/tu-proyecto-gcp/mlops-challenge-api-repo/delay-api:1"

project_id = "YOUR_GCP_PROJECT_ID"
region     = "us-central1"
app_name   = "mlops-challenge-api"

# Sustituye PROJECT y TAG tras el primer push (debe coincidir con repository_id = "${app_name}-repo")
image = "us-central1-docker.pkg.dev/YOUR_GCP_PROJECT_ID/mlops-challenge-api-repo/delay-api:1"

# Opcional: durante revisión del challenge, sube a 1 para evitar cold start en Locust
# min_instances = 1

# Por defecto true = basado en solicitudes. Para CPU siempre asignada: cpu_request_based = false
# cpu_request_based = true
